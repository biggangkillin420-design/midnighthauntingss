{
  "entities": {
    "article": {
      "title": "Article",
      "description": "Health articles, updates, or announcements",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "content", "status"]
    },
    "pageContent": {
      "title": "Page Content",
      "description": "Dynamic content for various pages",
      "type": "object",
      "properties": {
        "pageId": { "type": "string" },
        "sectionId": { "type": "string" },
        "content": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["pageId", "sectionId", "content"]
    },
    "siteSettings": {
      "title": "Site Settings",
      "description": "Global design and configuration settings",
      "type": "object",
      "properties": {
        "theme": { "type": "string" },
        "colors": { "type": "object" },
        "fonts": { "type": "object" },
        "layout": { "type": "object" }
      }
    },
    "faq": {
      "title": "FAQ",
      "description": "Frequently Asked Questions",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["question", "answer"]
    },
    "service": {
      "title": "Service",
      "description": "Services offered by the organization",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "price": { "type": "string" }
      },
      "required": ["name", "description"]
    },
    "pricingPlan": {
      "title": "Pricing Plan",
      "description": "Membership tiers and pricing",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "period": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "isPopular": { "type": "boolean" },
        "buttonText": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "lead": {
      "title": "Lead",
      "description": "Contact form submissions and leads",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "contacted", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "mediaAsset": {
      "title": "Media Asset",
      "description": "Uploaded images and assets",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "name"]
    },
    "navItem": {
      "title": "Navigation Item",
      "description": "Menu link configuration",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "path": { "type": "string" },
        "order": { "type": "number" },
        "isVisible": { "type": "boolean" }
      },
      "required": ["label", "path", "order"]
    }
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": "article",
      "description": "Collection of blog posts, updates, and changelogs"
    },
    "/pageContent/{pageId}": {
      "schema": "pageContent",
      "description": "Dynamic content, SEO, and section configuration for site pages"
    },
    "/settings/global": {
      "schema": "siteSettings",
      "description": "Global site configuration and SEO defaults"
    },
    "/pricingPlans/{planId}": {
      "schema": "pricingPlan",
      "description": "Membership and pricing tier configurations"
    },
    "/leads/{leadId}": {
      "schema": "lead",
      "description": "Lead capture and contact submissions"
    },
    "/media/{assetId}": {
      "schema": "mediaAsset",
      "description": "Media library assets"
    },
    "/navigation/{itemId}": {
      "schema": "navItem",
      "description": "Site navigation menu items"
    },
    "/faqs/{faqId}": {
      "schema": "faq",
      "description": "Frequently asked questions"
    },
    "/services/{serviceId}": {
      "schema": "service",
      "description": "Services list"
    }
  }
}
